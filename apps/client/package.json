{
  "name": "@repo/client",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:reset": "expo start --clear",
    "android": "expo run:android",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "ios:rebuild": "expo run:ios --clean",
    "android:rebuild": "expo run:android --clean",
    "ios": "expo run:ios",
    "device": "expo run:ios --device",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:web": "expo export --platform web",
    "build:web:dev": "set -a && source .env.development && set +a && expo export --platform web --clear",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "dev": "expo run:ios",
    "build:ios:preview": "eas build --local --non-interactive --platform ios --profile preview",
    "build:ios:prod": "eas build --local --non-interactive --platform ios --profile production",
    "build:android:preview": "eas build --local --non-interactive --platform android --profile preview",
    "build:android:prod": "eas build --local --non-interactive --platform android --profile production",
    "build:dev": "eas build --local --non-interactive --profile development",
    "submit:ios:preview": "eas submit --platform ios --profile preview",
    "submit:ios:prod": "eas submit --platform ios --profile production",
    "submit:android:preview": "eas submit --platform android --profile preview",
    "submit:android:prod": "eas submit --platform android --profile production",
    "beta:ios": "eas build --platform ios --profile preview --non-interactive",
    "beta:android": "eas build --platform android --profile preview --non-interactive"
  },
  "dependencies": {
