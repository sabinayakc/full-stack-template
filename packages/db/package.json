{
  "name": "@repo/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts --force",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "db:extensions": "tsx --env-file=.env ./src/extensions/index.ts",
    "db:seed": "tsx --env-file=.env ./src/seeds/index.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
